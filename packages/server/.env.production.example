# Paseo Production Environment
# Copy to .env and fill in values before starting in production mode.

# Required — daemon state directory
PASEO_HOME=~/.paseo

# Required — listen address (0.0.0.0 for Docker, 127.0.0.1 for local)
PASEO_LISTEN=0.0.0.0:6767

# Required in production — daemon auth password (bcrypt-hashed internally)
PASEO_PASSWORD=

# Production mode — enables strict config validation
NODE_ENV=production

# Logging — json format for structured log ingestion
PASEO_LOG_LEVEL=info
PASEO_LOG_FORMAT=json

# OpenAI API key (for speech/TTS)
OPENAI_API_KEY=

# Optional — relay for remote access
# PASEO_RELAY_ENABLED=true
# PASEO_RELAY_ENDPOINT=relay.paseo.sh:443

# Optional — Sentry error tracking DSN
# SENTRY_DSN=https://key@o123.ingest.sentry.io/456

# Optional — CORS origins (comma-separated)
# PASEO_CORS_ORIGINS=https://app.paseo.sh

# Optional — HMAC secret for tamper-evident audit logs
# PASEO_AUDIT_HMAC_SECRET=

# Optional — enable X-Forwarded-For parsing when behind a reverse proxy (Caddy/nginx).
# Set to 1 to trust the first hop. Enabled automatically in production (NODE_ENV=production)
# unless explicitly overridden here. Set to 0 to disable even in production.
# PASEO_TRUST_PROXY=1
